# Copy to .env and populate in the approved runtime environment.

ASKSAGE_INSTANCE=asksage.ai
ASKSAGE_APPROVED_HOSTS=api.asksage.ai
ASKSAGE_EMAIL=
ASKSAGE_API_KEY=
ASKSAGE_ACCESS_TOKEN=
ASKSAGE_MODEL=gpt-4.1-mini
ASKSAGE_CONNECT_TIMEOUT_SECONDS=10
ASKSAGE_READ_TIMEOUT_SECONDS=60
ASKSAGE_MAX_RETRIES=3
ASKSAGE_BACKOFF_FACTOR=0.5
ASKSAGE_DATASET_GUIDANCE_ID=
ASKSAGE_DATASET_DASHBOARD_PAYLOAD_ID=
ASKSAGE_DATASET_ONTOLOGY_ID=

PROJECT_DATA_DIR=data
PROJECT_CONFIG_DIR=config
LOG_LEVEL=INFO
