# Names-only template. Supply values through the approved environment/secret-injection
# method. On Windows, scripts/start_insights.ps1 explicitly loads only the approved runtime
# names from a local .env; direct Python entry points do not auto-load .env.

# Your approved AskSage instance hostname only. No `https://`, path, or credentials.
# `asksage.ai` becomes `api.asksage.ai` in this project. 
ASKSAGE_INSTANCE=asksage.ai
# Comma-separated API-host allowlist. Include the exact resulting
# API host, such as `api.asksage.ai` or your approved organiation API hostname. 
ASKSAGE_APPROVED_HOSTS=api.asksage.ai
# Email address of the AskSage account that owns the API key
ASKSAGE_EMAIL=
# API key generated for that AskSage account; keep it in secret storage. 
# AskSage documents generating it in Account Settings. 
ASKSAGE_API_KEY=
# A bearer access token, if your organization provides one directly. 
# It take precedence over email/API-key exchange
# Leave blank if using the email/API-key pair.
ASKSAGE_ACCESS_TOKEN=
# Exact model idenifier enables for your organization, e.g., the degault `gpt-4.1-mini`.
ASKSAGE_MODEL=gpt-4.1-mini
# Maximum seconds allowed to establish a connection. 
# 10 is a sensible default. 
ASKSAGE_CONNECT_TIMEOUT_SECONDS=10
# Maximum seconds waiting for AskSage's response after connection. 
# 60 is a sensible default. 
ASKSAGE_READ_TIMEOUT_SECONDS=60
# Number of automatic retries for transient errors such as timeouts, rate limites, and 5xx errors. 
# 3 is a sensible default. 
ASKSAGE_MAX_RETRIES=3
# Retry-delay multiplier in seconds. 
# 0.5 provides short increaseing waits. 
ASKSAGE_BACKOFF_FACTOR=0.5
# Reserved for the AskSage dataset ID containing approved CEPE guidance/reference documents. 
ASKSAGE_DATASET_GUIDANCE_ID=
# Reserved for an AskSage dataset ID containing aggregate dashboard summaries and metric definitions. 
ASKSAGE_DATASET_DASHBOARD_PAYLOAD_ID=
# Reserved for an AskSage dataset ID containing ontology/graph exports. 
ASKSAGE_DATASET_ONTOLOGY_ID=
# Set true only after the selected tenant model has been approved and verified to interpret
# PNG input through /server/query_with_file. The approved Windows startup script explicitly
# enables this value for its server run.
ASKSAGE_IMAGE_INPUT_SUPPORTED=True

# Optional approved PEM bundle override for Requests. Usually unnecessary when
# pip-system-certs can use the organization-managed OS trust store. Set in the
# server process environment when organizational PKI guidance requires it.
REQUESTS_CA_BUNDLE=

PROJECT_DATA_DIR=data
PROJECT_CONFIG_DIR=config
LOG_LEVEL=INFO
